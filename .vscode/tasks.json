{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "install deps",
      "type": "shell",
      "command": "pnpm install",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "www: dev",
      "detail": "Run the marketing site (agentreflex.dev) on http://localhost:3000",
      "type": "shell",
      "command": "pnpm --filter @agentreflex/www dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "group": "agentreflex", "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "docs: dev",
      "detail": "Run the Fumadocs docs (docs.agentreflex.dev) on http://localhost:3333",
      "type": "shell",
      "command": "pnpm --filter @agentreflex/docs dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "group": "agentreflex", "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "docs: build (static export)",
      "detail": "Build the docs to apps/docs/out for Cloudflare Pages",
      "type": "shell",
      "command": "pnpm --filter @agentreflex/docs build",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "group": "agentreflex", "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "dev: site + docs",
      "detail": "Start the www site and the docs together",
      "dependsOn": ["www: dev", "docs: dev"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "build: packages",
      "type": "shell",
      "command": "pnpm -r --filter \"./packages/*\" --filter \"./reflexes/*\" build",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "check: lint + types",
      "type": "shell",
      "command": "pnpm biome check . && pnpm -r typecheck",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
