{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bump-minor-pre-major": true,
  "include-component-in-tag": true,
  "packages": {
    "packages/core": { "package-name": "@agentreflex/core", "release-as": "0.1.0" },
    "packages/adapters": { "package-name": "@agentreflex/adapters", "release-as": "0.1.0" },
    "packages/cli": {
      "package-name": "agentreflex",
      "extra-files": ["src/cli.ts"],
      "release-as": "0.1.0"
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "agentreflex",
      "components": ["@agentreflex/core", "@agentreflex/adapters", "agentreflex"]
    }
  ]
}
